---
layout: default
---
{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="post">
  <header class="post-header">
    {% if page.collection == 'projects' and (page.external or page.github) %}
      <div class="post-title-row">
        <h1 class="post-title">{{ page.title }}</h1>
        <p class="project-links">
          {% if page.external %}<a href="{{ page.external }}" target="_blank" rel="noopener">Visit project ↗</a>{% endif %}
          {% if page.external and page.github %} · {% endif %}
          {% if page.github %}<a href="{{ page.github }}" target="_blank" rel="noopener">GitHub ↗</a>{% endif %}
        </p>
      </div>
    {% else %}
      <h1 class="post-title">{{ page.title }}</h1>
    {% endif %}
    <p class="post-description">{{ page.description }}</p>
    {% if page.collection == 'projects' %}<hr class="post-divider" />{% endif %}
  </header>

  <article>
    {{ content }}
  </article>

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>
